   "id": "871a0340",
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_model(f1, f2, f3, f4):\n",
    "    model = models.Sequential([\n",
    "        layers.Input(shape=(32,32,3)),\n",
    "\n",
    "        layers.Conv2D(f1, (3,3), activation='relu', padding='same'),\n",
    "        layers.Conv2D(f2, (3,3), activation='relu', padding='same'),\n",
    "        layers.MaxPooling2D((2,2)),\n",
    "\n",
    "        layers.Conv2D(f3, (3,3), activation='relu', padding='same'),\n",
    "        layers.Conv2D(f4, (3,3), activation='relu', padding='same'),\n",
    "        layers.MaxPooling2D((2,2)),\n",
    "\n",
    "        layers.Flatten(),\n",
    "        layers.Dense(256, activation='relu'),\n",
    "        layers.Dense(10, activation='softmax')\n",
    "    ])\n",
    "    return model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "e133dfb8",
   "metadata": {},
   "outputs": [],
   "source": [
    "small_model = build_model(8, 8, 16, 16)\n",
    "medium_model = build_model(32, 32, 64, 64)\n",
    "large_model = build_model(64, 64, 128, 128)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 75,
   "id": "26ab3055",
   "metadata": {},
   "outputs": [],
   "source": [
    "def compile_model(model):\n",
    "    model.compile(\n",
    "        optimizer=tf.keras.optimizers.Adam(learning_rate=0.001),\n",
    "        loss='categorical_crossentropy',\n",
    "        metrics=['accuracy']\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 76,
   "id": "38eb0797",
   "metadata": {},
   "outputs": [],
   "source": [
    "compile_model(small_model)\n",
    "compile_model(medium_model)\n",
    "compile_model(large_model)"
   ]
  },
